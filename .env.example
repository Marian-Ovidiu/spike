# Spike bot — Binance Spot BTCUSDT paper trading (public market data only; no API keys required).
# Copy to `.env` and adjust. See README for migration notes from Polymarket.

# --- Binance (read by live feed; defaults shown) ---
BINANCE_SYMBOL=BTCUSDT
# Optional: log bid/ask/mid every N bookTicker updates (0 = off). Example: 200
# BINANCE_FEED_DEBUG_LOG_EVERY_N=0
# Warn if mid unchanged for this many consecutive book updates (default 5000)
# BINANCE_FEED_WARN_UNCHANGED_MID_AFTER=5000

# --- Strategy & risk (see src/config.ts defaults) ---
SPIKE_THRESHOLD=0.005
TRADABLE_SPIKE_MIN_PERCENT=0.0015
RANGE_THRESHOLD=0.0012
STABLE_RANGE_SOFT_TOLERANCE_RATIO=1.5
MAX_PRIOR_RANGE_FOR_NORMAL_ENTRY=0.0015
HARD_REJECT_PRIOR_RANGE_PERCENT=0.002
STRONG_SPIKE_HARD_REJECT_POOR_RANGE=false
STRONG_SPIKE_CONFIRMATION_TICKS=1
EXCEPTIONAL_SPIKE_PERCENT=0.0025
EXCEPTIONAL_SPIKE_OVERRIDES_COOLDOWN=true

# Max bid/ask spread (basis points) to allow a paper entry (filters wide books).
MAX_ENTRY_SPREAD_BPS=40
SPIKE_MIN_RANGE_MULT=2.2

BORDERLINE_MIN_RATIO=0.85
BORDERLINE_WATCH_TICKS=2
BORDERLINE_REQUIRE_PAUSE=true
BORDERLINE_REQUIRE_NO_CONTINUATION=true
BORDERLINE_CONTINUATION_THRESHOLD=0.25
BORDERLINE_REVERSION_THRESHOLD=0.2
BORDERLINE_PAUSE_BAND_PERCENT=0.00015

# Spot paper exits (basis points vs entry fill)
TAKE_PROFIT_BPS=35
STOP_LOSS_BPS=25
PAPER_SLIPPAGE_BPS=3
PAPER_FEE_ROUND_TRIP_BPS=8

INITIAL_CAPITAL=10000
RISK_PERCENT_PER_TRADE=1
STAKE_PER_TRADE=30
EXIT_TIMEOUT_MS=90000
ENTRY_COOLDOWN_MS=120000
PRICE_BUFFER_SIZE=20

ALLOW_WEAK_QUALITY_ENTRIES=false
ALLOW_WEAK_QUALITY_ONLY_FOR_STRONG_SPIKES=true
ALLOW_ACCEPTABLE_QUALITY_STRONG_SPIKES=false
WEAK_QUALITY_SIZE_MULTIPLIER=0.5
STRONG_QUALITY_SIZE_MULTIPLIER=1
EXCEPTIONAL_QUALITY_SIZE_MULTIPLIER=1
UNSTABLE_CONTEXT_MODE=hard

# Feed health (Binance WebSocket bookTicker + aggTrade)
FEED_STALE_MAX_AGE_MS=15000
BLOCK_ENTRIES_ON_STALE_FEED=true

# --- Diagnostics ---
TEST_MODE=false
TEST_MODE_SOFT_UNSTABLE=false
DEBUG_MONITOR=false
PAPER_POSITION_MTM_DEBUG=false

# --- Deprecated (Polymarket / binary markets) — ignored with a warning if set ---
# POLYMARKET_MARKET_SLUG=
# POLYMARKET_MARKET_ID=
# POLYMARKET_DISCOVERY_QUERY=
# POLYMARKET_DISCOVERY_MIN_CONFIDENCE=
# BINARY_MARKET_SOURCE=
# UP_SIDE_PRICE=
# DOWN_SIDE_PRICE=
