# --- Canonical names (binary-first) ---
# Prefer BINARY_* for optional Polymarket execution, BINARY_SIGNAL_* for the BTC signal feed,
# and FEED_STALE_MAX_AGE_MS for Binance signal / legacy spot book staleness.
# Legacy POLYMARKET_* / MAX_OPPOSITE_* / SIGNAL_MODE / PAPER_SLIPPAGE_BPS still work but log warnings.
# Startup `logConfig()` prints canonical=… · from=… for each resolved setting.
#
# === Core synthetic lab (default) ===
# No BINARY_MARKET_* / BINARY_CONDITION_ID / AUTO_DISCOVER — execution is the demo YES/NO book.
# Optional: BINARY_UP_PRICE / BINARY_DOWN_PRICE (defaults 0.51 / 0.49 in code if unset).
MARKET_MODE=binary
AUTO_DISCOVER_BINARY_MARKET=false
# Legacy only: required when MARKET_MODE=spot (deprecated single-feed Binance execution paper).
# Also required for `npm run backtest` (CSV replay still uses that simulation path).
# LEGACY_SPOT_MARKET_MODE=1
BORDERLINE_MAX_LIFETIME_MS=8000
BORDERLINE_FAST_PROMOTE_DELTA_BPS=4
BORDERLINE_FAST_PROMOTE_PROB_DELTA=0.04
# Borderline delayed-entry watch: off by default (binary-first funnel). Strong spikes then require strong/exceptional pre-entry quality only.
ENABLE_BORDERLINE_MODE=false
# Strong-spike (quality still below full "exceptional" tier): enter same tick, no confirmation,
# when move >= FRACTION × max(TRADABLE_SPIKE_MIN_PERCENT, EXCEPTIONAL_SPIKE_PERCENT). 0 = require confirmation.
STRONG_SPIKE_EARLY_ENTRY_EXCEPTIONAL_FRACTION=0.7
# When borderline mode is on: extra floor on window spike threshold ratio (0 = disable this gate).
BORDERLINE_ENTRY_MIN_THRESHOLD_RATIO=0.94
BORDERLINE_ENTRY_REQUIRES_STABLE_RANGE=true
# Same-direction continuation cancel during watch (bps); 0 disables fast reject.
BORDERLINE_FAST_REJECT_SAME_DIRECTION_BPS=0
# When 1, refuse MARKET_MODE=spot (binary-first deployments). Binance spot signal for binary is unchanged.
BINARY_ONLY_RUNTIME=0
TEST_MODE=false
BLOCK_ENTRIES_ON_STALE_FEED=true
FEED_STALE_MAX_AGE_MS=15000
BINARY_SIGNAL_SOURCE=binance_spot
BINARY_SIGNAL_SYMBOL=BTCUSDT
BINARY_TAKE_PROFIT_PRICE_DELTA=0.05
BINARY_STOP_LOSS_PRICE_DELTA=0.05
BINARY_EXIT_TIMEOUT_MS=90000
BINARY_MAX_ENTRY_PRICE=0.99
# Skip entries when YES mid is outside [BINARY_YES_MID_BAND_MIN, BINARY_YES_MID_BAND_MAX] (near-resolution).
BINARY_YES_MID_EXTREME_FILTER_ENABLED=true
BINARY_YES_MID_BAND_MIN=0.05
BINARY_YES_MID_BAND_MAX=0.95
# Binary venue spread hard cap (basis points). Entries rejected above this. 0 = disabled.
BINARY_HARD_MAX_SPREAD_BPS=20
# Binary only: no fills with persisted entry path strong_spike_immediate (confirmation / borderline unchanged).
BINARY_DISABLE_IMMEDIATE_STRONG_SPIKE=false
BINARY_MAX_OPPOSITE_SIDE_ENTRY_PRICE=0.78
MONITOR_OUTPUT_DIR=output/monitor
DEBUG_MONITOR=false
PROBABILITY_WINDOW_SIZE=12
PROBABILITY_TIME_HORIZON_MS=30000
PROBABILITY_SIGMOID_K=4
SYNTHETIC_SPREAD_BPS=30
SYNTHETIC_SLIPPAGE_BPS=3
MAX_LIQUIDITY_PER_TRADE=0
# Synthetic execution only: venue YES mid is not a raw copy of model P(up) — lag / noise / bias / partial adjustment.
# Optional preset: slow | balanced | reactive | noisy (unset = no profile; use explicit SYNTHETIC_MARKET_* only).
# SYNTHETIC_MARKET_PROFILE=balanced
# Defaults (0 lag, alpha=1, 0 noise/bias) preserve near-legacy behaviour unless a profile is set.
SYNTHETIC_MARKET_REACTION_ALPHA=1
SYNTHETIC_MARKET_LAG_TICKS=0
SYNTHETIC_MARKET_NOISE_BPS=0
SYNTHETIC_MARKET_BIAS_BPS=0
SYNTHETIC_MARKET_NOISE_SEED=2654435769
# Extra spread from fair volatility / instability EWM (0 = off). Capped by SYNTHETIC_MARKET_MAX_SPREAD_BPS.
SYNTHETIC_MARKET_WIDEN_ON_VOLATILITY=0
# SYNTHETIC_MARKET_MAX_SPREAD_BPS=280
# When 1, prints one `[synthetic-venue]` line per ready tick (without full DEBUG_MONITOR).
SYNTHETIC_VENUE_PRICE_LOG=0
MIN_EDGE_THRESHOLD=0
MAX_TRADE_SIZE=0
MIN_TRADE_SIZE=1
RISK_PERCENT_PER_TRADE=1
# Paper entry slippage (bps). Prefer BINARY_PAPER_SLIPPAGE_BPS; PAPER_SLIPPAGE_BPS is a legacy alias.
BINARY_PAPER_SLIPPAGE_BPS=3

# === Optional: Polymarket Gamma live execution (uncomment as needed) ===
# Exactly ONE of: BINARY_MARKET_ID, BINARY_MARKET_SLUG, BINARY_CONDITION_ID — or set AUTO_DISCOVER_BINARY_MARKET=true
# BINARY_MARKET_SLUG=
# BINARY_MARKET_ID=
# BINARY_CONDITION_ID=
# AUTO_DISCOVER_BINARY_MARKET=true
# BINARY_POLL_INTERVAL_MS=10000
# BINARY_QUOTE_STALE_MAX_MS=120000
# BINARY_POLL_SILENCE_MAX_MS=60000
# BINARY_GAMMA_BOOTSTRAP_LOG=0
